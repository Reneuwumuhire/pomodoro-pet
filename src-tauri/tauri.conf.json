{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Petomato",
  "version": "2.1.3",
  "identifier": "com.rene.petomato",
  "build": {
    "frontendDist": "../dist-web",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:web"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; media-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://api.github.com",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$AUDIO/**",
          "$HOME/**"
        ]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "Petomato",
        "width": 420,
        "height": 600,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "shadow": false,
        "visible": true,
        "url": "index.html"
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "dmg",
      "app",
      "nsis",
      "msi"
    ],
    "category": "Productivity",
    "copyright": "© Rene Uwumuhire",
    "shortDescription": "A retro-LCD Pomodoro timer with a pixel pet that grows as you focus.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      },
      "entitlements": "Entitlements.plist",
      "exceptionDomain": ""
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English"
        ]
      },
      "allowDowngrades": true
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE2MUYyNkExNTEzRkYxQzQKUldURThUOVJvU1lmcHB6UDF2QXlrQkF1bVc0dlZxaXo4dEk4UVFISzh4R1NPRFhUVTV5c0J0amEK",
      "endpoints": [
        "https://github.com/Reneuwumuhire/petomato/releases/latest/download/latest.json"
      ]
    }
  }
}
