<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required so the focus-shield can drive browsers/System Events via AppleScript. -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    <key>NSAppleEventsUsageDescription</key>
    <string>Petomato checks the active app and browser tab to block distractions during strict-mode focus sessions.</string>
  </dict>
</plist>
